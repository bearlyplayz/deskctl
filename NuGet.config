<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Central package management requires either a single source or explicit source
       mapping. Machine-level configs add private feeds that this project does not
       consume; clearing and declaring nuget.org keeps restore reproducible on any box. -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
